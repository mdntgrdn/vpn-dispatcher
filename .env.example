###############################################################################
# Gateway config
#
# Flow: client → inbound AWG (awg-in) → Xray (routing) → egress below.
#
# Xray classifies each flow (POLICY_*, geosite/geoip) and stamps an fwmark.
# Policy routing then sends that mark into the matching TABLE_* / interface.
#
# Egress (exits from this server — where we proxy traffic):
#   Forti / Cisco / WG / AWG — corporate or fallback tunnels
#   direct — WAN of this host (Russian GeoIP/GeoSite and MARK_DIRECT)
###############################################################################

# --- Deploy (Ansible on the controller → remote host) ---
DEPLOY_HOST=203.0.113.10
DEPLOY_USER=root
DEPLOY_PORT=22
DEPLOY_SSH_KEY=~/.ssh/id_ed25519
DEPLOY_PATH=/opt/vpn-dispatcher
# ansible-playbook --become (sudo) when DEPLOY_USER is not root
DEPLOY_SUDO=false

# true  = share host network; AWG fallback uses host iface (see AWG_OUT_INTERFACE)
# false = Docker bridge; AWG fallback is a local awg-out client (see AWG_OUT_ENDPOINT)
HOST_NETWORK=true

# --- Inbound AWG (clients connect here) ---
PUBLIC_HOST=vpn.example.com
AWG_LISTEN_PORT=51820
AWG_SUBNET=10.77.0.0/30
AWG_DNS=1.1.1.1
AWG_MTU=1380
# Public NIC on the host. Required when HOST_NETWORK=true and AWG_OUT_ENABLED=true
WAN_IFACE=eth0

# Leave AWG_SERVER_PRIVATE_KEY empty to generate once under /opt/vpn-dispatcher/data/awg/
AWG_SERVER_PRIVATE_KEY=
AWG_JC=4
AWG_JMIN=40
AWG_JMAX=70
AWG_S1=50
AWG_S2=50
AWG_S3=50
AWG_S4=50
AWG_H1=1
AWG_H2=2
AWG_H3=3
AWG_H4=4
# Optional: AWG_I1='<r 2><b 0x...>'
AWG_I1=
AWG_I2=
AWG_I3=
AWG_I4=
AWG_I5=

# --- Egress: AWG fallback (unmatched traffic after policies + RU geo) ---
AWG_OUT_ENABLED=false

# Used when HOST_NETWORK=true: mark → host uplink iface (no local peer)
AWG_OUT_INTERFACE=awg-uplink
AWG_OUT_SNAT=10.40.0.253

# Used when HOST_NETWORK=false: local awg-out client → one peer
AWG_OUT_ADDRESS=10.88.0.2/32
# Leave empty to generate once under /opt/vpn-dispatcher/data/
AWG_OUT_PRIVATE_KEY=
AWG_OUT_PEER_PUBLIC_KEY=REPLACE_WITH_PEER_PUBLIC_KEY
AWG_OUT_PRESHARED_KEY=
AWG_OUT_ENDPOINT=host.docker.internal:51821
AWG_OUT_ALLOWED_IPS=0.0.0.0/0
AWG_OUT_KEEPALIVE=25
AWG_OUT_MTU=1380
AWG_OUT_JC=4
AWG_OUT_JMIN=40
AWG_OUT_JMAX=70
AWG_OUT_S1=50
AWG_OUT_S2=50
AWG_OUT_S3=50
AWG_OUT_S4=50
AWG_OUT_H1=1
AWG_OUT_H2=2
AWG_OUT_H3=3
AWG_OUT_H4=4
# Optional: AWG_OUT_I1='<r 2><b 0x...>'
AWG_OUT_I1=
AWG_OUT_I2=
AWG_OUT_I3=
AWG_OUT_I4=
AWG_OUT_I5=

# --- Egress: WireGuard (POLICY_WG_* → this tunnel) ---
WG_OUT_ENABLED=false
WG_OUT_ADDRESS=10.89.0.2/32
# Leave empty to generate once under /opt/vpn-dispatcher/data/
WG_OUT_PRIVATE_KEY=
WG_OUT_PEER_PUBLIC_KEY=REPLACE_WITH_PEER_PUBLIC_KEY
WG_OUT_PRESHARED_KEY=
WG_OUT_ENDPOINT=wg.example.com:51820
WG_OUT_ALLOWED_IPS=0.0.0.0/0
WG_OUT_KEEPALIVE=25
WG_OUT_MTU=1380

# --- Egress: FortiGate SSL VPN (POLICY_FORTI_* → this tunnel; browser SAML) ---
FORTI_ENABLED=false
FORTI_HOST=vpn.example.com
FORTI_PORT=443
FORTI_REALM=
FORTI_USER=
FORTI_TRUSTED_CERT=
# Bridge mode: publish host FORTI_SAML_PORT → container FORTI_SAML_PROXY_PORT
FORTI_SAML_PORT=8020
FORTI_SAML_PROXY_PORT=18020

# --- Egress: Cisco AnyConnect (POLICY_CISCO_* → this tunnel) ---
CISCO_ENABLED=false
CISCO_HOST=vpn.example.com
CISCO_PORT=443
CISCO_GROUP=
CISCO_USER=
CISCO_PASSWORD=
# otpauth://totp/...?secret=BASE32 or raw Base32 secret
CISCO_TOTP_URI=
CISCO_SERVER_CERT=
CISCO_PROTOCOL=anyconnect
CISCO_MTU=1350

# --- Xray routing (classifier) ---
# Domains/CIDRs below are matched first; then configured geosite/geoip → direct;
# everything else → AWG fallback (if enabled) or direct.
# Values are Loyalsoldier (or your) dat categories — not hardcoded to RU.
XRAY_DIRECT_GEOSITE=category-ru
XRAY_DIRECT_GEOIP=ru
XRAY_GEO_UPDATE_URL=https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download
POLICY_FORTI_DOMAINS=
POLICY_FORTI_CIDRS=
POLICY_CISCO_DOMAINS=domain:partner.example.org
POLICY_CISCO_CIDRS=10.30.0.0/16
POLICY_WG_DOMAINS=domain:private.example.net
POLICY_WG_CIDRS=10.40.0.0/16

# --- Container / marks / tables ---
CONTAINER_NAME=vpn-dispatcher
DOCKER_IMAGE=vpn-dispatcher:local

# Required. Prefer MARK_*=TABLE_* (same id). Xray sets the mark; ip rule uses the table.
# MARK_DIRECT has no TABLE_* — it uses the main routing table (WAN).
MARK_DIRECT=900
MARK_FORTI=901
MARK_CISCO=902
MARK_WG=903
TABLE_FORTI=901
TABLE_CISCO=902
TABLE_WG=903

# When HOST_NETWORK=true, MARK_AWG / TABLE_AWG must match the host uplink
# (its fwmark and routing table). They need not be the same number.
# When HOST_NETWORK=false you may set TABLE_AWG=904 to match the mark.
MARK_AWG=904
TABLE_AWG=210
